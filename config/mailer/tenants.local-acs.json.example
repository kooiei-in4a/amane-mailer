{
  "version": 1,
  "environment": "develop",
  "tenants": [
    {
      "tenant_id": "00000000-0000-0000-0000-000000000101",
      "name": "your-service-name",
      "source_services": ["your-service-name"],
      "default_from": {
        "email": "noreply@your-domain.example.com",
        "display_name": "Your Service"
      },
      "token_env": "MAIL_SERVICE_TOKEN",
      "provider": "acs",
      "live_sending": true,
      "metadata_max_bytes": 4096,
      "retry": {
        "max_attempts": 10,
        "initial_delay_seconds": 10,
        "max_delay_seconds": 300
      }
    }
  ]
}
