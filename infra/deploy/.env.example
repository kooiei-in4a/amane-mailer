# Copy to .env on the deploy host and replace all placeholder values.
# Do not commit the real .env file.

# ── Required: Project ────────────────────────────────────
COMPOSE_PROJECT_NAME=amane-mailer

# ── Required: Image ──────────────────────────────────────
MAILER_IMAGE_REPOSITORY=ghcr.io/YOUR_GITHUB_ORG/amane-mailer
MAILER_IMAGE_TAG=sha-replace-with-published-git-sha
MAILER_PULL_POLICY=always

# ── Required: Paths and connection ───────────────────────
MAILER_DATA_PATH=./data
MAILER_TENANTS_HOST_PATH=./tenants.json
MAILER_TENANTS_CONTAINER_PATH=/app/config/mailer/tenants.json
MAILER_CONNECTION_STRING=Data Source=/app/data/mailer.db
MAILER_HTTP_PORT=8080
ASPNETCORE_FORWARDEDHEADERS_ENABLED=false

# ── Required: Network ────────────────────────────────────
MAILER_NETWORK_NAME=amane_mailer
MAILER_NETWORK_ALIAS=mailer

# ── Required: Resources ──────────────────────────────────
MAILER_MEM_LIMIT=512m
MAILER_CPUS=1.0
MAILER_STOP_GRACE_PERIOD=120s

# ── Required: Health check ───────────────────────────────
MAILER_HEALTHCHECK_INTERVAL=30s
MAILER_HEALTHCHECK_TIMEOUT=5s
MAILER_HEALTHCHECK_RETRIES=5
MAILER_HEALTHCHECK_START_PERIOD=20s

# ── Required: Logging ────────────────────────────────────
LOG_MAX_SIZE=10m
LOG_MAX_FILE=5

# ── Required: Tenant tokens ──────────────────────────────
# Single-tenant setup: set MAIL_SERVICE_TOKEN only.
# Multi-tenant setup: set MAIL_SERVICE_TOKEN_DEVELOP / _STAGING / _PRODUCTION.
# Use MAIL_SERVICE_TOKEN for simple single-tenant files (token_env: MAIL_SERVICE_TOKEN).
MAIL_SERVICE_TOKEN=replace-with-private-token

# Shared 3-tenant tenants.json maps token_env -> env var (must all be distinct).
# Adjust the variable names to match your tenant configuration.
MAIL_SERVICE_TOKEN_DEVELOP=replace-with-private-develop-token
MAIL_SERVICE_TOKEN_STAGING=replace-with-private-staging-token
MAIL_SERVICE_TOKEN_PRODUCTION=replace-with-private-production-token

# ── Optional: Provider override ──────────────────────────
# Leave blank to use provider values from tenant JSON.
MAILER_PROVIDER=

# ── Required: ACS live sending ───────────────────────────
# Required only for provider=acs and approved live sending.
ACS_CONNECTION_STRING=

# ── Optional: Retention ──────────────────────────────────
MAILER_RETENTION_DAYS=90
MAILER_RETENTION_SWEEP_INTERVAL_HOURS=24

# ── Optional: Admin UI ───────────────────────────────────
# Admin UI is disabled by default. Enable only behind an approved access path.
# Generate AMANE_ADMIN_PASSWORD_HASH with:
#   docker compose --env-file .env -f compose.yml run --rm -T --no-deps mailer admin hash-password
# Keep AMANE_ADMIN_ALLOW_HTTP=false on the deploy host; TLS should terminate at the reverse proxy.
# Keep AMANE_ADMIN_BIND=127.0.0.1 unless the approved reverse proxy reaches the container over Docker networking.
AMANE_ADMIN_ENABLED=false
AMANE_ADMIN_USERNAME=admin
AMANE_ADMIN_PASSWORD_HASH=
AMANE_ADMIN_BIND=127.0.0.1
AMANE_ADMIN_ALLOW_HTTP=false
AMANE_ADMIN_PII_LIST_MODE=masked

# ── Optional: Backup ─────────────────────────────────────
# SQLite backup encryption and offsite upload (used by backup-mailer.sh)
# Generate a key pair with: age-keygen -o ./keys/backup-age-key.txt && age-keygen -y ./keys/backup-age-key.txt
# Set this to the recipient public key printed by age-keygen -y.
MAILER_BACKUP_ENCRYPTION_PUBLIC_KEY=replace-with-age-recipient-public-key

# rclone destination for encrypted backups. Use a placeholder in docs/issues;
# keep real remote names and credentials in private host operations.
# Leave empty only when MAILER_BACKUP_REQUIRE_OFFSITE=false.
MAILER_BACKUP_RCLONE_REMOTE=remote:bucket-or-prefix/mailer/

# Path to rclone config on the host. Omit to rely on RCLONE_CONFIG_* environment variables instead.
MAILER_BACKUP_RCLONE_CONFIG_PATH=./rclone/rclone.conf

# Fail the backup script if no offsite remote is configured. Keep true for real operations.
MAILER_BACKUP_REQUIRE_OFFSITE=true

# Optional dead-man ping URL (Healthchecks.io or Uptime Kuma push). Leave empty to skip.
MAILER_BACKUP_PING_URL=
